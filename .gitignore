# Styx runtime artifacts — generated, not source

# Plugin-compiled output cache
data/_compiled/
data/_compile_cache/

# Per-server data stores (generated by plugins at runtime)
data/*.sessions.json
data/*.state.json
data/*.cooldowns.json
data/*.zones.json
data/*.tracker.json
data/StyxBackpack/
data/StyxTeleport/
data/StyxShield/
data/StyxBuilder/
data/PermEditor.last_open.json

# Server-meta progression runtime state (Economy / Rewards / Leveling / Shop)
data/StyxEconomy.wallet.json
data/StyxLeveling.wallet.json
data/StyxLeveling.wallet.wiped-*.json
data/StyxEconomy.wallet.wiped-*.json
data/StyxRewards.state.json
data/WelcomeMessage.seen.json
data/StyxShop/

# Live permissions file is per-server (contains real player Steam IDs).
# Ship the sanitised template instead — the framework looks for the .json,
# so on first run users copy or rename permissions.example.json.
data/permissions.json

# Logs
logs/
*.log

# Generated game-data references — regenerated on demand by /gamerefs
data/game_refs/

# Auto-generated label cache (rebuilt at boot)
data/_labels/

# Plugin manifest synthesis output -- regenerated at every boot from the
# embedded /* @styx-... */ blocks in plugin .cs files. Each file carries a
# "Generated by Styx PluginManifestSynthesiser. Do not hand-edit." header
# and is rebuilt from the plugin .cs sources, so it's a build artifact, not
# source -- a fresh clone synthesises them on first boot. The synthesiser
# writes the real vanilla filenames directly (there is no _styx_generated_*
# namespace), so ignore those names.
Config/buffs.xml
Config/entityclasses.xml
Config/entitygroups.xml
Config/spawning.xml
Config/Localization.txt
Config/XUi/windows.xml
Config/XUi/xui.xml

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Build artifacts
*.pdb
bin/
obj/

# Pre-compiled plugin demo (HelloSource ships as the .cs equivalent)
plugins/Styx.Hello.dll
